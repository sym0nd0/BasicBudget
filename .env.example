# ─── Required ─────────────────────────────────────────────────────────────────

# At least 32 random characters — used to sign session cookies
# Generate with: openssl rand -hex 32
SESSION_SECRET=<run: openssl rand -hex 32>

# Exactly 64 hex chars (32 bytes) — used for AES-256-GCM TOTP secret encryption
# Generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=<run: openssl rand -hex 32>

# ─── Application ──────────────────────────────────────────────────────────────

# Public URL of the app (no trailing slash) — used in email links
APP_URL=http://localhost:5173

# CORS origin — must match the frontend origin in production
CORS_ORIGIN=http://localhost:5173

# Path to the SQLite database file
DB_PATH=data/basicbudget.db

# ─── SMTP & OIDC ──────────────────────────────────────────────────────────────
#
# SMTP and OIDC settings are now configured through the Admin Panel at
# /admin/settings (visible to admin users only).
#
# On first startup, if SMTP_HOST / OIDC_ISSUER_URL are present in the
# environment, they are automatically migrated into the database so that
# existing deployments continue to work without manual intervention.
#
# For new deployments, log in as the first registered user (auto-promoted to
# admin) and configure SMTP/OIDC through the UI.

# ─── Runtime ──────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001
