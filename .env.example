# ─── Required ─────────────────────────────────────────────────────────────────

# At least 32 random characters — used to sign session cookies
# Generate with: openssl rand -hex 32
SESSION_SECRET=<run: openssl rand -hex 32>

# Exactly 64 hex chars (32 bytes) — used for AES-256-GCM TOTP secret encryption
# Generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=<run: openssl rand -hex 32>

# ─── Application ──────────────────────────────────────────────────────────────

# Public URL of the app (no trailing slash) — used in email links
APP_URL=http://localhost:5173

# CORS origin — must match APP_URL in production
CORS_ORIGIN=http://localhost:5173

# Path to the SQLite database file
DB_PATH=data/basicbudget.db

# ─── Runtime ──────────────────────────────────────────────────────────────────

# These values apply to bare Node.js (npm run dev) only.
# Docker ignores them — the Dockerfile sets NODE_ENV=production and PORT=3000
# internally. PORT below is also used by compose.yml to set the host port
# (default 8080). Change PORT here to expose the container on a different port.
NODE_ENV=development
PORT=3001

# Cookie security (default: true in production, false in development)
# Only needed if APP_URL is http:// — a startup warning will fire in that case.
# With Secure=true over plain HTTP, browsers silently drop cookies — sessions will fail.
# COOKIE_SECURE=false
