{
  "name": "basicbudget",
  "private": true,
  "version": "2.33.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "build": "npm run build:frontend && npm run build:server",
    "build:frontend": "tsc -b && vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "start": "node dist-server/server/index.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "screenshots": "tsx scripts/screenshot.ts"
  },
  "dependencies": {
    "@types/ua-parser-js": "^0.7.39",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "openid-client": "^6.3.4",
    "otpauth": "^9.3.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
